{
  "name": "satora",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/sync-sdk-examples.mjs",
    "prebuild": "node scripts/sync-sdk-examples.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "serve": "next start",
    "typecheck": "tsc",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "deploy": "node scripts/sync-sdk-examples.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "node scripts/sync-sdk-examples.mjs && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "node scripts/sync-sdk-examples.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.27",
    "@opennextjs/cloudflare": "^1.19.5",
    "@types/react": "^19.2.14",
    "ai": "^5.0.93",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.8.7",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.7",
    "lucide-react": "^0.553.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "24.10.1",
    "autoprefixer": "^10.5.0",
    "dprint": "^0.54.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "postcss-import": "^16.1.1",
    "typescript": "~5.6.2",
    "wrangler": "^4.87.0"
  },
  "engines": {
    "node": ">=18.0"
  },
  "packageManager": "yarn@4.6.0",
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,md,mdx,json,yml,yaml,toml}": "dprint fmt --"
  }
}
